{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Note": {
      "title": "Note",
      "description": "A markdown note",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "subject": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "rawContent": { "type": "string" },
        "subfolder": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "subject", "title", "content", "createdAt", "updatedAt"]
    },
    "UserSettings": {
      "title": "UserSettings",
      "description": "User specific settings and folders",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "subjectFolders": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "dailyRecommendations": {
          "type": "array",
          "items": { "type": "string" }
        },
        "lastScanDate": { "type": "string", "format": "date" },
        "lastBacklinkScanDate": { "type": "string", "format": "date" }
      },
      "required": ["userId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/notes/{noteId}": {
      "schema": { "$ref": "#/entities/Note" },
      "description": "User notes"
    },
    "/userSettings/{userId}": {
      "schema": { "$ref": "#/entities/UserSettings" },
      "description": "User settings and folders"
    }
  }
}
